generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model StravaConnection {
  id            String   @id @default(cuid())
  userId        String   @unique @db.Uuid
  athleteId     String
  athleteName   String?
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  scope         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExportSnapshot {
  id           String   @id @default(cuid())
  userId       String   @db.Uuid
  rangeStart   DateTime
  rangeEnd     DateTime
  activityJson String
  createdAt    DateTime @default(now())

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Activity {
  id                 BigInt   @id
  userId             String   @db.Uuid
  athleteId          String
  name               String
  type               String
  distance           Float
  movingTime         Int
  elapsedTime        Int
  timezone           String?
  rawJson            Json
  classification     String
  analysisLabel      String
  startDate          DateTime
  hasDistanceData    Boolean
  distanceMeters     Float
  movingTimeSeconds  Int
  elapsedTimeSeconds Int
  elevationGainMeters Float
  averageSpeed       Float
  maxSpeed           Float
  averageHeartrate   Float?
  maxHeartrate       Float?
  averageWatts       Float?
  weightedAverageWatts Int?
  maxWatts           Int?
  kilojoules         Float?
  deviceWatts        Boolean?
  calories           Float?
  description        String?
  zonesJson          String?
  providerMetricsJson String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([athleteId, startDate])
  @@index([userId, startDate])
}

model Profile {
  id                String            @id @db.Uuid
  email             String            @default("")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  sessions          UserSession[]
  stravaConnection  StravaConnection?
  exportSnapshots   ExportSnapshot[]
  activities        Activity[]
}

model UserSession {
  id             String   @id @default(cuid())
  sessionToken   String   @unique
  userId         String   @db.Uuid
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
