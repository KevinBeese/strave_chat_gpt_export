generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model StravaConnection {
  id            String   @id @default(cuid())
  userId        String?  @unique
  athleteId     String
  athleteName   String?
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  scope         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, athleteId])
}

model ExportSnapshot {
  id           String   @id @default(cuid())
  userId       String?
  rangeStart   DateTime
  rangeEnd     DateTime
  activityJson String
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model StravaActivity {
  id                 String   @id @default(cuid())
  userId             String?
  stravaActivityId   BigInt
  athleteId          String
  name               String
  type               String
  classification     String
  analysisLabel      String
  startDate          DateTime
  hasDistanceData    Boolean
  distanceMeters     Float
  movingTimeSeconds  Int
  elapsedTimeSeconds Int
  elevationGainMeters Float
  averageSpeed       Float
  maxSpeed           Float
  averageHeartrate   Float?
  maxHeartrate       Float?
  averageWatts       Float?
  weightedAverageWatts Int?
  maxWatts           Int?
  kilojoules         Float?
  deviceWatts        Boolean?
  calories           Float?
  description        String?
  zonesJson          String?
  providerMetricsJson String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stravaActivityId])
  @@index([athleteId, startDate])
  @@index([userId, startDate])
}

model User {
  id                String            @id @default(cuid())
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  sessions          UserSession[]
  stravaConnection  StravaConnection?
  exportSnapshots   ExportSnapshot[]
  stravaActivities  StravaActivity[]
}

model UserSession {
  id             String   @id @default(cuid())
  sessionToken   String   @unique
  userId         String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
