DATABASE_URL="postgresql://postgres:postgres@localhost:5432/strava_export?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/strava_export?schema=public"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_SUPABASE_URL="https://<your-project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-supabase-anon-key>"
SESSION_SECRET="replace-this-with-a-long-random-string"

STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
STRAVA_REDIRECT_URI="http://localhost:3000/api/strava/callback"
STRAVA_RETRY_MAX_ATTEMPTS="4"
STRAVA_RETRY_BASE_DELAY_MS="500"

