APP_ENV="prod"
NEXT_PUBLIC_APP_ENV="prod"
APP_URL="https://strava-export.example.com"
PORT="3001"

DATABASE_URL="postgresql://postgres:postgres@localhost:5434/strava_export_prod?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5434/strava_export_prod?schema=public"

NEXT_PUBLIC_SUPABASE_URL="https://<your-prod-project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-prod-supabase-anon-key>"
SESSION_SECRET="replace-this-with-a-long-random-string"

STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
STRAVA_REDIRECT_URI="https://strava-export.example.com/api/strava/callback"
STRAVA_RETRY_MAX_ATTEMPTS="4"
STRAVA_RETRY_BASE_DELAY_MS="500"
STRAVA_REQUEST_TIMEOUT_MS="15000"

SUPERADMIN_BOOTSTRAP_CODE=""
ADMIN_CODE_HASH_PEPPER=""

WAHOO_CLIENT_ID=""
WAHOO_CLIENT_SECRET=""
WAHOO_REDIRECT_URI="https://strava-export.example.com/api/auth/wahoo/callback"
WAHOO_OAUTH_SCOPES="user_read workouts_read"
