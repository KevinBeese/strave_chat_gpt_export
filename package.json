{
  "name": "strava-gpt-export",
  "version": "1.0.0",
  "description": "Local Next.js MVP to export Strava activities for ChatGPT analysis.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:local": "bash ./scripts/run-with-env.sh ./.env.development.local next dev -p 3000",
    "dev:flavor": "bash ./scripts/run-with-env.sh ./.env.development.local next dev -p 3000",
    "build": "prisma generate && next build",
    "build:dev": "bash ./scripts/run-with-env.sh ./.env.development.local npm run build",
    "build:prod": "bash ./scripts/run-with-env.sh ./.env.production.local npm run build",
    "start": "next start",
    "start:prod": "npm run prisma:push && npm run start",
    "preview:prod:local": "bash ./scripts/run-with-env.sh ./.env.production.local npm run build && bash ./scripts/run-with-env.sh ./.env.production.local npm run start:prod",
    "db:up": "docker compose -f docker-compose.local.yml up -d",
    "db:down": "docker compose -f docker-compose.local.yml down",
    "db:logs": "docker compose -f docker-compose.local.yml logs -f",
    "seed:sample": "node ./scripts/seed-sample-data.mjs",
    "seed:sample:dev": "bash ./scripts/run-with-env.sh ./.env.development.local npm run seed:sample",
    "seed:sample:prod": "bash ./scripts/run-with-env.sh ./.env.production.local npm run seed:sample",
    "test": "vitest run",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:setup": "npm run prisma:push && npm run prisma:generate",
    "prisma:setup:dev": "bash ./scripts/run-with-env.sh ./.env.development.local npm run prisma:setup",
    "prisma:setup:prod": "bash ./scripts/run-with-env.sh ./.env.production.local npm run prisma:setup"
  },
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.49.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "next": "^16.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tesseract.js": "^7.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "postcss": "^8.5.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
